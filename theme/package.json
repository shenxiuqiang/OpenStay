{
  "name": "@openstay/theme",
  "version": "0.1.0",
  "description": "OpenStay Theme System - 共享 UI 主题与组件库",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./themes/*": {
      "import": "./src/themes/*/index.ts",
      "types": "./src/themes/*/index.ts"
    },
    "./components/*": {
      "import": "./src/components/*/index.ts",
      "types": "./src/components/*/index.ts"
    }
  },
  "scripts": {
    "build": "echo 'Theme package - no build needed'",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
