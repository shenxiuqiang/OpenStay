{
  "name": "@openstay/property",
  "version": "0.1.0",
  "description": "OpenStay Property Studio - 单店数字店面 Blocklet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "blocklet dev",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p api/tsconfig.json",
    "clean": "rm -rf dist api/dist .blocklet",
    "lint": "tsc --noEmit && eslint src api/src --ext .mjs,.js,.jsx,.ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "bundle": "npm run build && blocklet bundle",
    "start": "NODE_ENV=production node api/dist/index.js"
  },
  "dependencies": {
    "@arcblock/did-auth": "^1.21.0",
    "@blocklet/sdk": "^1.16.0",
    "@openstay/theme": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "i18next": "^23.8.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "morgan": "^1.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^6.22.0",
    "sequelize": "^6.37.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}
