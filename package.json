{
  "name": "openstay",
  "version": "0.1.0",
  "description": "去中心化住宿预订网络 | Decentralized Hospitality Network",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "hospitality",
    "hotel",
    "booking",
    "decentralized",
    "blocklet",
    "did",
    "nft",
    "openstay"
  ],
  "author": "OpenStay Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.0",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.27",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.0.0",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "property/web",
    "hub/web",
    "travel-app/*",
    "theme/*"
  ]
}
