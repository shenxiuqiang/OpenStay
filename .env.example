# OpenStay Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# Common Settings
# ===========================================
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================

# Option 1: Use DATABASE_URL (recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/openstay

# Option 2: Use individual variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openstay
DB_USER=openstay
DB_PASSWORD=your_secure_password
DB_SSL=false

# SQLite fallback (if PostgreSQL is not configured)
# SQLITE_PATH=./data/openstay.sqlite

# ===========================================
# Map Services API Keys
# ===========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
AMAP_KEY=your_amap_key
BAIDU_MAP_KEY=your_baidu_map_key

# ===========================================
# Property Studio (Port 3030)
# ===========================================
PROPERTY_PORT=3030
PROPERTY_DATABASE_URL=postgresql://user:password@localhost:5432/openstay_property

# ===========================================
# Hospitality Hub (Port 3031)
# ===========================================
HUB_PORT=3031
HUB_DATABASE_URL=postgresql://user:password@localhost:5432/openstay_hub

# ===========================================
# Travel App (Port 3032)
# ===========================================
TRAVEL_APP_PORT=3032
TRAVEL_APP_DATABASE_URL=postgresql://user:password@localhost:5432/openstay_travel

# ===========================================
# Security
# ===========================================
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_here

# ===========================================
# External Services
# ===========================================
# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# SMS Service
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# ===========================================
# Feature Flags
# ===========================================
ENABLE_MAP=true
ENABLE_BOOKING=true
ENABLE_PAYMENT=false
ENABLE_NOTIFICATIONS=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# NFT & Blockchain Configuration
# ===========================================
CHAIN_HOST=https://beta.abtnetwork.io/api
TOKEN_ID=z35n6UoVxBsV9dUHVHC8uhkZU2L4qh9PZW52

# NFT Factory Addresses (set after creating factories)
NODE_NFT_FACTORY=
PROPERTY_CERTIFICATE_FACTORY=
HOST_MEMBERSHIP_SILVER_FACTORY=
HOST_MEMBERSHIP_GOLD_FACTORY=
HOST_MEMBERSHIP_DIAMOND_FACTORY=

# Wallet Mnemonic (NEVER commit this!)
# OPENSTAY_MNEMONIC=your_secret_mnemonic_here
